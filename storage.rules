rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function normalizedContentType() {
      return request.resource != null && request.resource.contentType != null
        ? request.resource.contentType
        : "";
    }

    function hasBlockedPublicExtension(fileName) {
      return fileName.matches('.*\\.(html|htm|js|mjs|cjs|svg|svgz|xml|xhtml|php|exe|dll|sh|bat|cmd|ps1|jar|msi|apk|ipa)$');
    }

    function hasAllowedPublicContentType() {
      let ct = normalizedContentType();
      return ct.matches('image/.*')
        || ct.matches('audio/.*')
        || ct == 'application/pdf'
        || ct == 'text/plain'
        || ct == 'application/json';
    }

    function isSafePublicAsset(fileName) {
      return !hasBlockedPublicExtension(fileName) && hasAllowedPublicContentType();
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function roleFromToken() {
      return isSignedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : "";
    }

    function hasAnyRole(roles) {
      return isSignedIn() && roles.hasAny([roleFromToken()]);
    }

    function hasRole(role) {
      return isSignedIn() && roleFromToken() == role;
    }

    function isAdmin() {
      return hasAnyRole([
        "admin", "Admin", "administrador", "Administrador", "administrator", "Administrator",
        "superAdmin", "superadmin", "SuperAdmin", "owner", "Owner"
      ]);
    }

    function isEditor() {
      return isAdmin() ||
        hasAnyRole([
          "author", "Author", "autor", "Autor", "autores", "autoria", "Autoria",
          "editor", "Editor", "editorial", "Editorial",
          "developer", "Developer", "desarrollo", "Desarrollo", "dev", "Dev",
          "designer", "Designer", "diseno", "Diseño", "disenador", "Diseñador"
        ]);
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn() && conversationId.matches("^" + request.auth.uid + "_.+$|^.+_" + request.auth.uid + "$");
    }

    // Imagenes generadas para lecturas game/editor.
    match /lecturas-agent/{uid}/{sourceCollection}/{lecturaId}/{fileName} {
      allow read: if true;
      allow write: if (isEditor() || isOwner(uid)) && isSafePublicAsset(fileName);
    }

    // Assets de lecturas publicadas (públicos de lectura para runtime game).
    match /lecturasASC/{allPaths=**} {
      allow read: if true;
      allow write: if isEditor() && hasAllowedPublicContentType();
    }

    match /lecturasNuevas/{allPaths=**} {
      allow read: if true;
      allow write: if isEditor() && hasAllowedPublicContentType();
    }

    // Música generada/manual para lecturas.
    match /lecturas_music/{sourceCollection}/{lecturaId}/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isSafePublicAsset(fileName);
    }

    // Galería personal del generador de imágenes.
    match /images/{uid}/{allPaths=**} {
      allow read, write: if isOwner(uid);
    }

    // Biblioteca compartida de mindmaps.
    match /mindmap/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && hasAllowedPublicContentType();
    }

    // Assets de unidades generadas (para evitar base64 en Firestore).
    // Estructura: unidadesGeneradasAssets/{nivel}/{grado}/{trimestre}/{unidad}/{uid}/{fileName}
    match /unidadesGeneradasAssets/{nivel}/{grado}/{trimestre}/{unidad}/{uid}/{fileName} {
      allow read: if isSignedIn() && isSafePublicAsset(fileName);
      allow write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    // Adjuntos de chat.
    match /chat_images/{conversationId}/{fileName} {
      allow read, write: if isConversationParticipant(conversationId) && isSafePublicAsset(fileName);
    }

    // Archivos grandes de análisis/síntesis por sesión de audioTranslate.
    match /analyses/{sessionId}/{fileName} {
      allow read, write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    match /syntheses/{sessionId}/{fileName} {
      allow read, write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    match /sessions/{sessionId}/{fileName} {
      allow read, write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    match /audiolibros/{sessionId}/{fileName} {
      allow read, write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    match /podcaster/sessions/{sessionId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && isSafePublicAsset(fileName);
    }
    match /podcaster/sessions/{sessionId}/{subDir}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && isSafePublicAsset(fileName);
    }

    // Deny-by-default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
